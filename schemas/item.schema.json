{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Unjuno/llmclozestat/schemas/item.schema.json",
  "title": "llmclozestat item",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "dataset_id",
    "probe_id",
    "variant_id",
    "item_id",
    "version",
    "language",
    "translation_relation",
    "equivalence_level",
    "item_type",
    "primary_skill",
    "secondary_tags",
    "validation_target",
    "claim_scope",
    "text_with_blanks",
    "segments",
    "blanks",
    "expected_full_texts",
    "ambiguity_level",
    "source_type",
    "review_status"
  ],
  "properties": {
    "dataset_id": {"type": "string", "minLength": 1},
    "probe_id": {"type": "string", "minLength": 1},
    "variant_id": {"type": "string", "minLength": 1},
    "item_id": {"type": "string", "minLength": 1},
    "version": {"type": "string", "minLength": 1},
    "language": {"type": "string", "minLength": 2},
    "translation_relation": {
      "type": "string",
      "enum": ["original", "human_translation", "adapted_translation", "non_equivalent_probe"]
    },
    "equivalence_level": {
      "type": "string",
      "enum": ["strict", "near", "adapted", "not_equivalent"]
    },
    "source_variant_id": {"type": ["string", "null"]},
    "translation_notes": {"type": ["string", "null"]},
    "item_type": {"type": "string", "minLength": 1},
    "primary_skill": {"type": "string", "minLength": 1},
    "secondary_tags": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "validation_target": {
      "type": "object",
      "additionalProperties": true,
      "required": ["main_question", "hypothesis", "success_condition", "why_this_item_exists"],
      "properties": {
        "main_question": {"type": "string", "minLength": 1},
        "hypothesis": {"type": "string", "minLength": 1},
        "success_condition": {"type": "string", "minLength": 1},
        "why_this_item_exists": {"type": "string", "minLength": 1}
      }
    },
    "claim_scope": {
      "type": "object",
      "additionalProperties": true,
      "required": ["supports_claim", "does_not_support", "required_conditions", "generalization_limit"],
      "properties": {
        "supports_claim": {"type": "string", "minLength": 1},
        "does_not_support": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "required_conditions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "generalization_limit": {"type": "string", "minLength": 1}
      }
    },
    "text_with_blanks": {"type": "string", "minLength": 1},
    "segments": {
      "type": "array",
      "minItems": 2,
      "items": {"type": "string"}
    },
    "blanks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["blank_id", "position", "primary_skill", "accepted_fills", "near_miss_fills"],
        "properties": {
          "blank_id": {"type": "string", "minLength": 1},
          "position": {"type": "integer", "minimum": 1},
          "primary_skill": {"type": "string", "minLength": 1},
          "accepted_fills": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {"type": "string", "minLength": 1}
          },
          "near_miss_fills": {
            "type": "array",
            "uniqueItems": true,
            "items": {"type": "string"}
          },
          "known_wrong_fills": {
            "type": "array",
            "uniqueItems": true,
            "items": {"type": "string", "minLength": 1}
          },
          "expected_error_patterns": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true,
              "required": ["fill", "interpretation"],
              "properties": {
                "fill": {"type": "string", "minLength": 1},
                "interpretation": {"type": "string", "minLength": 1}
              }
            }
          },
          "context_distance": {
            "type": "string",
            "enum": ["local", "sentence", "cross_sentence", "long_context"]
          },
          "depends_on": {
            "type": "array",
            "uniqueItems": true,
            "items": {"type": "string", "minLength": 1}
          },
          "evidence_span": {"type": "string"}
        }
      }
    },
    "expected_full_texts": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "ambiguity_level": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "source_type": {
      "type": "string",
      "enum": ["human_designed", "human_translated", "machine_assisted", "derived"]
    },
    "review_status": {
      "type": "string",
      "enum": ["draft", "reviewed", "deprecated"]
    },
    "notes": {"type": "string"}
  }
}
