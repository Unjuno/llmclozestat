{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Unjuno/llmclozestat/schemas/result.schema.json",
  "title": "llmclozestat result record",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "submitter_id",
    "run_id",
    "dataset_id",
    "model_id",
    "backend",
    "provider",
    "probe_id",
    "variant_id",
    "language",
    "primary_skill",
    "item_id",
    "trial_id",
    "prompt_template_id",
    "prompt_language",
    "support_mode",
    "f_shot",
    "blank_rendering",
    "generation_config",
    "raw_output",
    "normalized_output",
    "extraction_mode",
    "blank_results",
    "instruction_following_pass",
    "item_format_pass",
    "item_strict_pass",
    "item_partial_score",
    "latency_ms"
  ],
  "properties": {
    "submitter_id": {"type": "string", "minLength": 1},
    "run_id": {"type": "string", "minLength": 1},
    "dataset_id": {"type": "string", "minLength": 1},
    "model_id": {"type": "string", "minLength": 1},
    "model_source": {"type": ["string", "null"]},
    "quantization": {"type": ["string", "null"]},
    "backend": {"type": "string", "minLength": 1},
    "backend_version": {"type": ["string", "null"]},
    "provider": {"type": "string", "minLength": 1},
    "probe_id": {"type": "string", "minLength": 1},
    "variant_id": {"type": "string", "minLength": 1},
    "language": {"type": "string", "minLength": 2},
    "primary_skill": {"type": "string", "minLength": 1},
    "item_id": {"type": "string", "minLength": 1},
    "trial_id": {"type": "integer", "minimum": 1},
    "prompt_template_id": {"type": "string", "minLength": 1},
    "prompt_language": {"type": "string", "minLength": 2},
    "support_mode": {"type": "string", "enum": ["zero", "format_shot", "task_shot", "control_shot", "mixed_shot"]},
    "f_shot": {"type": "integer", "minimum": 0},
    "blank_rendering": {"type": "string", "minLength": 1},
    "generation_config": {
      "type": "object",
      "additionalProperties": true,
      "required": ["temperature", "max_tokens"],
      "properties": {
        "temperature": {"type": ["number", "null"], "minimum": 0},
        "top_p": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
        "seed": {"type": ["integer", "null"]},
        "max_tokens": {"type": "integer", "minimum": 1},
        "context_window": {"type": ["integer", "null"], "minimum": 1},
        "repeat_penalty": {"type": ["number", "null"]},
        "stop": {"type": "array", "items": {"type": "string"}}
      }
    },
    "generation_config_hash": {"type": ["string", "null"]},
    "raw_output": {"type": "string"},
    "normalized_output": {"type": "string"},
    "extraction_mode": {"type": "string", "enum": ["exact_full_text", "segment", "fallback_answer_phrase"]},
    "blank_results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["blank_id", "position", "extracted_fill", "fill_class", "blank_parse_pass", "content_pass", "parse_fail"],
        "properties": {
          "blank_id": {"type": "string", "minLength": 1},
          "position": {"type": "integer", "minimum": 1},
          "primary_skill": {"type": "string"},
          "context_distance": {"type": "string", "enum": ["local", "sentence", "cross_sentence", "long_context"]},
          "extracted_fill": {"type": ["string", "null"]},
          "fill_class": {"type": "string", "enum": ["accepted", "near_miss", "known_wrong", "wrong", "format_fail", "parse_fail"]},
          "blank_parse_pass": {"type": "boolean"},
          "content_pass": {"type": "boolean"},
          "parse_fail": {"type": "boolean"},
          "content_score_f1": {"type": ["number", "null"], "minimum": 0, "maximum": 1}
        }
      }
    },
    "instruction_following_pass": {"type": "boolean"},
    "item_format_pass": {"type": "boolean"},
    "item_strict_pass": {"type": "boolean"},
    "item_partial_score": {"type": "number", "minimum": 0, "maximum": 1},
    "format_score_f1": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
    "format_score_edit": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
    "latency_ms": {"type": "number", "minimum": 0}
  }
}
