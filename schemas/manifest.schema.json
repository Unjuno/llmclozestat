{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/llmclozestat/schemas/manifest.schema.json",
  "title": "llmclozestat submission manifest",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "manifest_version",
    "submitter_id",
    "run_id",
    "created_at",
    "hash_algorithm",
    "files",
    "package_hash",
    "package_hash_input"
  ],
  "properties": {
    "manifest_version": {
      "type": "string",
      "minLength": 1
    },
    "submitter_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "hash_algorithm": {
      "type": "string",
      "enum": ["sha256"]
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["path", "sha256"],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1,
            "pattern": "^(?!/)(?!.*\\.\\.)(?!.*//).+$",
            "description": "Relative path inside the submission package. Absolute paths and parent traversal are forbidden."
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "size_bytes": {
            "type": ["integer", "null"],
            "minimum": 0
          }
        }
      }
    },
    "package_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "package_hash_input": {
      "type": "string",
      "minLength": 1
    },
    "notes": {
      "type": ["string", "null"]
    }
  }
}
